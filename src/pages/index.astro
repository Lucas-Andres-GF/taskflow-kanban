---
import Layout from '../layouts/Layout.astro';
import KanbanBoard from '../components/KanbanBoard.jsx';
---

<Layout title="TaskFlow - Kanban Board">
  <div class="space-y-6">
    <!-- Page Title -->
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-xl text-gray-300">Tablero Kanban</h2>
        <p id="taskCount" class="text-sm text-gray-500 mt-1">Cargando...</p>
      </div>
      
      <!-- Refresh button -->
      <button
        id="refreshBtn"
        class="flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-600 hover:bg-gray-700 transition-colors text-gray-400 hover:text-white"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Actualizar
      </button>
    </div>

    <!-- Kanban Board (React Island) -->
    <KanbanBoard client:load />
  </div>

  <script>
    // Listen for task count updates from React component
    window.addEventListener('taskCountUpdate', (e) => {
      document.getElementById('taskCount').textContent = e.detail + ' tareas totales';
    });
    
    // Refresh button - reload page
    document.getElementById('refreshBtn')?.addEventListener('click', () => {
      window.location.reload();
    });
  </script>
</Layout>